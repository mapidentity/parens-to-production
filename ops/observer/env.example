# Template for /etc/myapp-observer/env on the OBSERVER box — a small VPS
# in a different datacenter, ideally a different provider. root:root 0600.
# Values quoted: same two-grammar rule as the main box's env file.

TARGET_URL="https://myapp.example.com/health"
# The body must contain this, or "up" doesn't count:
EXPECT="\"status\":\"ok\""

# Consecutive failed runs (1/min) before the single alert fires. Two rides
# out a deploy window and a transient route flap without waking anyone.
FAILS_BEFORE_ALERT="2"
CERT_WARN_DAYS="14"

# The observer's OWN mail path. Use a different relay (or at least a
# different provider account) than production's: an observer that alerts
# through the relay it is observing goes silent exactly with its patient.
SMTP_HOST="smtp.other-relay.example.com"
SMTP_USER="observer"
SMTP_PASS="changeme"
SMTP_FROM="observer@myapp.example.com"
ALERT_EMAIL="you@example.com"

# STATE_DIR="/var/lib/myapp-observer"
