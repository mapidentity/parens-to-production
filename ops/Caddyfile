# Production Caddyfile. Structurally the same as the dev block
# (caddy/Caddyfile) with two deliberate differences: the upstream is the
# loopback address the :prod profile binds (not a compose hostname), and
# there is NO tls line — a real domain with a public DNS record gets its
# certificate from Let's Encrypt automatically, renewals included.
# Production TLS is the absence of configuration.
myapp.example.com {
	encode zstd gzip

	# Front-door limits — the "wall" the app repeatedly defers to (ch.21's
	# body cap, ch.45's slow-reader). A request body over 2 MB is refused
	# with 413 before it reaches the app: the recipe forms are kilobytes, so
	# this only ever stops an abusive upload from touching the single heap.
	request_body {
		max_size 2MB
	}

	# Access log, to stderr and therefore journald: the answer to "what hit
	# the box around the incident?" One JSON line per request; retention is
	# journald's, like every other log on this machine.
	log

	# Long-lived, request-invariant security headers (applied to every response).
	# The per-document Content-Security-Policy is set by the app, which owns the
	# inline-script hashes — Caddy must NOT set CSP or it would conflict.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
	}

	# The tree the CI pipeline ships (myapp/static/* -> /mnt/data/static).
	root * /mnt/data/static
	@static file
	handle @static {
		# Content-hashed filenames (styles.<hash>.css, dispatcher.<hash>.js) are immutable
		@hashed path_regexp \.([a-f0-9]{8})\.(css|js)$
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# Vendored libs are version-pinned in the filename, so equally immutable
		@vendor path /idiomorph-*.min.js /idiomorph-*.min.js.map
		header @vendor Cache-Control "public, max-age=31536000, immutable"

		# Static assets that rarely change
		@assets path *.svg *.png *.jpg *.woff2
		header @assets Cache-Control "public, max-age=604800"

		file_server
	}

	# Operator-only surface: the metrics endpoint is scraped from the box,
	# never served to the internet. From out here it does not exist.
	handle /metrics {
		respond 404
	}

	handle {
		# One pool serves both topologies: the single-instance unit
		# (myapp.service) binds 3000; the update pair (myapp@.service)
		# binds 3001/3002. Health checks steer traffic to whichever
		# instances are alive — during a pair deploy, briefly both.
		reverse_proxy 127.0.0.1:3000 127.0.0.1:3001 127.0.0.1:3002 {
			health_uri /health
			health_interval 2s
			fail_duration 10s
			lb_try_duration 4s
			# Bound the app-facing hop. dial_timeout catches an instance that
			# accepts TCP but never completes; response_header_timeout catches
			# one that took the request but never started answering (the
			# wedged-worker case). These time the HEADERS only — the SSE
			# presence stream (headers now, body forever) is untouched, which
			# is exactly why a full read-timeout is deliberately NOT set here.
			transport http {
				dial_timeout 5s
				response_header_timeout 15s
			}
			# The app binds loopback, so every request reaches it from
			# 127.0.0.1 — its own :remote-addr is useless for per-IP
			# controls. Hand it the real client, authoritatively:
			# {remote_host} is the TCP peer Caddy saw (the client, since
			# Caddy is the TLS edge), and header_up OVERWRITES any
			# X-Client-IP the client tried to forge.
			header_up X-Client-IP {remote_host}
		}
	}

	# The deploy window: while the app restarts, the proxy gets connection
	# refusals and would show a bare 502. Serve the branded maintenance page
	# instead — it refreshes itself until the app answers again.
	handle_errors {
		@upstream-down expression `{err.status_code} in [502, 503, 504]`
		handle @upstream-down {
			root * /mnt/data/static
			rewrite * /error/503.html
			header Cache-Control "no-store"
			header Retry-After "5"
			file_server {
				status 503
			}
		}
	}
}
