# Template for /etc/myapp/env — root:root, chmod 0600.
# Every value the :prod profile requires. Boot refuses to start with any
# of these missing (myapp.config/require-prod-config!), so a typo here is
# a named message in `journalctl -u myapp`, not a runtime surprise.

# Values are double-quoted because this file has two readers with two
# grammars: systemd's EnvironmentFile= (raw key=value) and the ops
# scripts, which `source` it — where an unquoted & in a JDBC URI would
# background half the line. Quotes satisfy both.
DATABASE_URI="datomic:sql://myapp?jdbc:postgresql://localhost:5432/datomic?user=datomic&password=datomic"
ANALYTICS_DATABASE_URI="datomic:sql://myapp-analytics?jdbc:postgresql://localhost:5432/datomic?user=datomic&password=datomic"

BASE_URL=https://myapp.example.com
ADMIN_EMAIL=you@example.com

# The AES-128 session key: 32 hex chars, decoded to the 16 key bytes —
# full 128-bit entropy. Generate with:  openssl rand -hex 16
# (A raw 16-character string also satisfies the length check, but carries
# only its characters' entropy — 16 hex chars would be 64 bits, half the
# cipher's strength. Prefer the hex spelling.)
SESSION_KEY=changeme-openssl-rand-hex-16
# At least 32 bytes (HMAC-SHA256): openssl rand -hex 32
SIGNING_KEY=changeme-openssl-rand-hex-32
# Both placeholders above FAIL the boot on purpose (wrong length): a box
# that never generated its keys must refuse to start, not run guessable.

# An authenticated relay with a reputation (see ch.25 on deliverability).
SMTP_HOST=smtp.example-relay.com
SMTP_USER=myapp
SMTP_PASS=changeme
SMTP_FROM=no-reply@myapp.example.com

# Optional — the ops scripts' knobs, with their defaults.
# BACKUP_DIR=/var/backups/myapp
# DATOMIC_HOME=/opt/datomic
# SMTP_PORT=587
# SMTP_TLS=true                       # "false" only for lab drills / port-25 internal relays
# MYAPP_UPLOADS_ROOT=/mnt/data/uploads  # must match the units' ReadWritePaths= grant

# The backup TARGET (myapp-backup.sh). The default file: target is on THIS
# box; production should point off-box (s3://…) — the copy that survives
# the box (ch.39/46).
# BACKUP_URI=file:/var/backups/myapp

# REQUIRED for the weekly restore drill (myapp-backup-verify.timer): a
# throwaway Datomic URI on scratch storage. The verify script REFUSES to
# run without it, so it can never restore over production — which means
# leaving this unset silently disables the drill; set it.
# VERIFY_SCRATCH_URI="datomic:sql://myapp?jdbc:postgresql://localhost:5432/datomic_verify?user=datomic&password=…"

# The out-of-band alert path (myapp-alert.sh, myapp-notify.sh): an
# ntfy/Slack/Discord/push HTTPS endpoint that does NOT route through the
# SMTP relay — the alert about a dead relay must not need the relay.
# ALERT_WEBHOOK_URL=https://ntfy.sh/your-private-topic

# The dead-man's-switch the watchdog pings when ALL checks pass
# (healthchecks.io, ntfy, any cron monitor): silence becomes an off-box
# alarm on a path independent of this box and its relay.
# HEARTBEAT_URL=https://hc-ping.com/your-uuid
