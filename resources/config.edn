{:server {;; In :prod the port is per-instance (MYAPP_PORT, set by the systemd
          ;; unit) so an update pair can run two builds side by side; unset,
          ;; it stays 3000 for the single-instance topology.
          :port #profile {:dev 3000
                          :prod #long #or [#env "MYAPP_PORT" "3000"]}
          :host #profile {:dev "0.0.0.0"
                          :prod "127.0.0.1"}}

 :database-uri #profile {:dev "datomic:mem://myapp-dev"
                         :prod #env "DATABASE_URI"}

 :analytics-database-uri #profile {:dev "datomic:mem://myapp-analytics-dev"
                                   :prod #env "ANALYTICS_DATABASE_URI"}

 :admin-email #profile {:dev "admin@myapp.lan"
                        :prod #env "ADMIN_EMAIL"}

 :base-url #profile {:dev "https://myapp.lan"
                     :prod #env "BASE_URL"}

 :session-key #env "SESSION_KEY"
 :signing-key #env "SIGNING_KEY"
 ;; Optional: the previous signing key, honoured during a rotation grace
 ;; window so in-flight magic links keep working. Set it to the old key at
 ;; rotation, drop it once outstanding links have expired (15 min).
 :signing-key-previous #env "SIGNING_KEY_PREVIOUS"

 :smtp {:host #profile {:dev "mailpit"
                        :prod #env "SMTP_HOST"}
        :port #profile {:dev 1025
                        :prod 587}
        :tls #profile {:dev false
                       :prod true}
        :user #profile {:dev nil
                        :prod #env "SMTP_USER"}
        :pass #profile {:dev nil
                        :prod #env "SMTP_PASS"}
        :from #profile {:dev "no-reply@myapp.lan"
                        :prod #env "SMTP_FROM"}}}
